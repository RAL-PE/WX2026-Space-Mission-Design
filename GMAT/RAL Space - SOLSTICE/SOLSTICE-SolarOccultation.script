GSAzores.Temperature = 295.1;
GSAzores.Pressure = 1013.5;
GSAzores.Humidity = 55;
GSAzores.MinimumElevationAngle = 7;

%----------------------------------------
%---------- ForceModels
%----------------------------------------

Create ForceModel EarthOrbitProp_ForceModel;
EarthOrbitProp_ForceModel.CentralBody = Earth;
EarthOrbitProp_ForceModel.PrimaryBodies = {Earth};
EarthOrbitProp_ForceModel.PointMasses = {Luna, Sun};
EarthOrbitProp_ForceModel.SRP = On;
EarthOrbitProp_ForceModel.RelativisticCorrection = Off;
EarthOrbitProp_ForceModel.ErrorControl = RSSStep;
EarthOrbitProp_ForceModel.GravityField.Earth.Degree = 4;
EarthOrbitProp_ForceModel.GravityField.Earth.Order = 4;
EarthOrbitProp_ForceModel.GravityField.Earth.StmLimit = 100;
EarthOrbitProp_ForceModel.GravityField.Earth.PotentialFile = 'JGM2.cof';
EarthOrbitProp_ForceModel.GravityField.Earth.TideModel = 'None';
EarthOrbitProp_ForceModel.SRP.Flux = 1367;
EarthOrbitProp_ForceModel.SRP.SRPModel = Spherical;
EarthOrbitProp_ForceModel.SRP.Nominal_Sun = 149597870.691;
EarthOrbitProp_ForceModel.Drag.AtmosphereModel = MSISE90;
EarthOrbitProp_ForceModel.Drag.HistoricWeatherSource = 'ConstantFluxAndGeoMag';
EarthOrbitProp_ForceModel.Drag.PredictedWeatherSource = 'ConstantFluxAndGeoMag';
EarthOrbitProp_ForceModel.Drag.CSSISpaceWeatherFile = 'SpaceWeather-All-v1.2.txt';
EarthOrbitProp_ForceModel.Drag.SchattenFile = 'SchattenPredict.txt';
EarthOrbitProp_ForceModel.Drag.F107 = 150;
EarthOrbitProp_ForceModel.Drag.F107A = 150;
EarthOrbitProp_ForceModel.Drag.MagneticIndex = 3;
EarthOrbitProp_ForceModel.Drag.SchattenErrorModel = 'Nominal';
EarthOrbitProp_ForceModel.Drag.SchattenTimingModel = 'NominalCycle';
EarthOrbitProp_ForceModel.Drag.DragModel = 'Spherical';

%----------------------------------------
%---------- Propagators
%----------------------------------------

Create Propagator EarthOrbitProp;
EarthOrbitProp.FM = EarthOrbitProp_ForceModel;
EarthOrbitProp.Type = RungeKutta89;
EarthOrbitProp.InitialStepSize = 60;
EarthOrbitProp.Accuracy = 9.999999999999999e-12;
EarthOrbitProp.MinStep = 0.001;
EarthOrbitProp.MaxStep = 2700;
EarthOrbitProp.MaxStepAttempts = 50;
EarthOrbitProp.StopIfAccuracyIsViolated = true;

%----------------------------------------
%---------- Coordinate Systems
%----------------------------------------

Create CoordinateSystem SolarVector;
SolarVector.Origin = SOLSTICE1;
SolarVector.Axes = ObjectReferenced;
SolarVector.XAxis = R;
SolarVector.ZAxis = N;
SolarVector.Primary = SOLSTICE1;
SolarVector.Secondary = Sun;

