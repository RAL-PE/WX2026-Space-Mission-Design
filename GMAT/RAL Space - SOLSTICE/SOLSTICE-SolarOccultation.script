%----------------------------------------
%---------- Formation
%----------------------------------------

Create Formation Formation1;
Formation1.Add = {SOLSTICE1, SOLSTICE2, SOLSTICE3};

%----------------------------------------
%---------- GroundStations
%----------------------------------------

Create GroundStation GSChilbolton;
GSChilbolton.OrbitColor = [0 255 0];
GSChilbolton.TargetColor = DarkGray;
GSChilbolton.CentralBody = Earth;
GSChilbolton.StateType = Spherical;
GSChilbolton.HorizonReference = Sphere;
GSChilbolton.Location1 = 51.14578123015045;
GSChilbolton.Location2 = 358.5612293965133;
GSChilbolton.Location3 = 0;
GSChilbolton.Id = 'Chilbolton';
GSChilbolton.IonosphereModel = 'None';
GSChilbolton.TroposphereModel = 'None';
GSChilbolton.DataSource = 'Constant';
GSChilbolton.Temperature = 295.1;
GSChilbolton.Pressure = 1013.5;
GSChilbolton.Humidity = 55;
GSChilbolton.MinimumElevationAngle = 7;

Create GroundStation GSAzores;
GSAzores.OrbitColor = [255 128 64];
GSAzores.TargetColor = DarkGray;
GSAzores.CentralBody = Earth;
